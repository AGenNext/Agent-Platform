# ── Platform ────────────────────────────────────────────────────────────────
PLATFORM_ENV=dev

# ── SurrealDB ────────────────────────────────────────────────────────────────
SURREALDB_URL=ws://localhost:8000/rpc
SURREALDB_NAMESPACE=agent_platform
SURREALDB_DATABASE=agent_platform
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
SURREALDB_PORT=8000

# ── Object storage (MinIO) ───────────────────────────────────────────────────
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Queue ────────────────────────────────────────────────────────────────────
QUEUE_BACKEND=local

# ── Model routing ────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_PORT=11434

# ── Service ports ────────────────────────────────────────────────────────────
AGENT_KNOWLEDGE_PORT=8001
AGENT_DASHBOARD_PORT=3000
AGENT_SITE_PORT=3001

# ── Service URLs (host-level, for scripts and local tooling) ─────────────────
AGENT_KNOWLEDGE_URL=http://localhost:8001
AGENT_DASHBOARD_URL=http://localhost:3000
AGENT_SITE_URL=http://localhost:3001
