# ── Platform ────────────────────────────────────────────────────────────────
PLATFORM_ENV=dev

# ── SurrealDB ────────────────────────────────────────────────────────────────
SURREALDB_URL=ws://localhost:8000/rpc
SURREALDB_NAMESPACE=agent_platform
SURREALDB_DATABASE=agent_platform
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
SURREALDB_PORT=8000

# ── Service ports ────────────────────────────────────────────────────────────
AGENT_DASHBOARD_PORT=3000
AGENT_SITE_PORT=3001

# ── Service URLs (host-level, for local tooling) ─────────────────────────────
AGENT_DASHBOARD_URL=http://localhost:3000
AGENT_SITE_URL=http://localhost:3001

# ── Public discovery URLs (.well-known manifests) ───────────────────────────
PUBLIC_PLATFORM_URL=http://localhost:3000
PUBLIC_SURREAL_API_URL=http://localhost:8000/api/agent_platform/agent_platform
PUBLIC_AGENT_DASHBOARD_URL=http://localhost:3000
PUBLIC_AGENT_SITE_URL=http://localhost:3001
