# ─────────────────────────────────────────────────────────────────────────────
# AGenNext Agent Platform — root environment template
# Copy to .env and fill in values. Never commit .env.
#
# Environments: local | staging | production
# ─────────────────────────────────────────────────────────────────────────────

PLATFORM_ENV=local

# ── SurrealDB ─────────────────────────────────────────────────────────────────
# local:      ws://localhost:8000/rpc
# staging:    wss://agent-surrealdb-staging.fly.dev/rpc
# production: wss://agent-surrealdb.fly.dev/rpc
SURREALDB_URL=ws://localhost:8000/rpc
SURREALDB_NAMESPACE=agent_platform
SURREALDB_DATABASE=agent_platform
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root

# ── Object storage (MinIO / S3-compatible) ────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=agent-artifacts
# For AWS S3 in production, set these instead:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# OBJECT_STORAGE_ENDPOINT=https://s3.amazonaws.com

# ── Service URLs ──────────────────────────────────────────────────────────────
# local:      http://localhost:8001
# production: https://agent-knowledge-api.fly.dev
AGENT_KNOWLEDGE_URL=http://localhost:8001
AGENT_DASHBOARD_URL=http://localhost:3000

# ── Dashboard (Vite build-time) ───────────────────────────────────────────────
# These are baked into the JS bundle at build time.
VITE_API_URL=http://localhost:8001
VITE_SURREALDB_URL=ws://localhost:8000/rpc
VITE_SURREALDB_NS=agent_platform
VITE_SURREALDB_DB=agent_platform

# ── LLM providers (optional — only needed for sample-agents) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Auth / JWT (production only) ──────────────────────────────────────────────
# JWT_SECRET=change-me-in-production-min-32-chars
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# ── CORS (production only) ────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://your-dashboard.netlify.app,https://your-domain.com

# ── Fly.io deploy (used by scripts/cloud_deploy.sh) ──────────────────────────
# FLY_API_TOKEN=
# SURREAL_ROOT_PASS=
# FLY_REGION=iad

# ── Netlify deploy ────────────────────────────────────────────────────────────
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
