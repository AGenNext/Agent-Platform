# ─────────────────────────────────────────────────────────────────────────────
# sample-agents environment
# Copy to .env — never commit .env
# ─────────────────────────────────────────────────────────────────────────────

# Platform API base URL
# local:      http://localhost:8001
# production: https://agent-knowledge-api.fly.dev
PLATFORM_URL=http://localhost:8001
PLATFORM_TENANT=tenant-demo

# LLM providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which agent to run when using docker compose --profile agents
# Options: researcher | orchestrator | memory | a2a | crewai | autogen | demo
AGENT_MODE=demo

# CrewAI (optional — only needed for crewai_integration.py)
# CREWAI_MODEL=claude-3-5-sonnet-20241022

# AutoGen (optional — only needed for autogen_integration.py)
# AUTOGEN_MODEL=claude-3-5-sonnet-20241022
