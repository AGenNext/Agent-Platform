# ─────────────────────────────────────────────────────────────────────────────
# agent-dashboard environment
# These are BAKED INTO the JS bundle at build time by Vite.
# Copy to .env.local for local dev — Vite reads .env.local automatically.
# Never commit .env.local
# ─────────────────────────────────────────────────────────────────────────────

# API base URL — all /api/* requests proxy here
# local:      http://localhost:8001   (Vite dev server proxies /api → this)
# production: https://agent-knowledge-api.fly.dev  (Netlify rewrites /api/*)
VITE_API_URL=http://localhost:8001

# SurrealDB WebSocket — used by LIVE SELECT (real-time RuntimePage)
# local:      ws://localhost:8000/rpc
# production: wss://agent-surrealdb.fly.dev/rpc
VITE_SURREALDB_URL=ws://localhost:8000/rpc
VITE_SURREALDB_NS=agent_platform
VITE_SURREALDB_DB=agent_platform
