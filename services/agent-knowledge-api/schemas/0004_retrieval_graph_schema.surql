-- AGenNext SurrealDB-native retrieval graph
-- Maps Microsoft GraphRAG and RAG-Anything into operational semantic graph tables.

DEFINE TABLE retrieval_corpora SCHEMAFULL;
DEFINE FIELD tenant_id ON retrieval_corpora TYPE record<tenants>;
DEFINE FIELD name ON retrieval_corpora TYPE string;
DEFINE FIELD semantic_id ON retrieval_corpora TYPE string;
DEFINE FIELD jsonld_context ON retrieval_corpora TYPE object;
DEFINE FIELD jsonld_type ON retrieval_corpora TYPE array<string> DEFAULT ['schema:Dataset', 'agx:RetrievalCorpus'];
DEFINE FIELD source_grounding_refs ON retrieval_corpora TYPE array<string> DEFAULT ['microsoft:graphrag', 'arxiv:2510.12323'];
DEFINE FIELD created_at ON retrieval_corpora TYPE datetime DEFAULT time::now();
DEFINE INDEX retrieval_corpora_tenant_semantic_unique ON retrieval_corpora FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE source_documents SCHEMAFULL;
DEFINE FIELD tenant_id ON source_documents TYPE record<tenants>;
DEFINE FIELD corpus_id ON source_documents TYPE record<retrieval_corpora>;
DEFINE FIELD name ON source_documents TYPE string;
DEFINE FIELD uri ON source_documents TYPE option<string>;
DEFINE FIELD content_hash ON source_documents TYPE option<string>;
DEFINE FIELD semantic_id ON source_documents TYPE string;
DEFINE FIELD jsonld_context ON source_documents TYPE object;
DEFINE FIELD jsonld_type ON source_documents TYPE array<string> DEFAULT ['schema:DigitalDocument', 'schema:CreativeWork'];
DEFINE FIELD source_grounding_refs ON source_documents TYPE array<string> DEFAULT [];
DEFINE FIELD created_at ON source_documents TYPE datetime DEFAULT time::now();
DEFINE INDEX source_documents_tenant_semantic_unique ON source_documents FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE document_regions SCHEMAFULL;
DEFINE FIELD tenant_id ON document_regions TYPE record<tenants>;
DEFINE FIELD document_id ON document_regions TYPE record<source_documents>;
DEFINE FIELD region_kind ON document_regions TYPE string;
DEFINE FIELD page_number ON document_regions TYPE option<int>;
DEFINE FIELD bounding_box ON document_regions TYPE option<object>;
DEFINE FIELD text ON document_regions TYPE option<string>;
DEFINE FIELD semantic_id ON document_regions TYPE string;
DEFINE FIELD jsonld_context ON document_regions TYPE object;
DEFINE FIELD jsonld_type ON document_regions TYPE array<string> DEFAULT ['schema:CreativeWork', 'agx:DocumentRegion'];
DEFINE FIELD created_at ON document_regions TYPE datetime DEFAULT time::now();
DEFINE INDEX document_regions_tenant_semantic_unique ON document_regions FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE knowledge_entities SCHEMAFULL;
DEFINE FIELD tenant_id ON knowledge_entities TYPE record<tenants>;
DEFINE FIELD name ON knowledge_entities TYPE string;
DEFINE FIELD entity_kind ON knowledge_entities TYPE string;
DEFINE FIELD semantic_id ON knowledge_entities TYPE string;
DEFINE FIELD aliases ON knowledge_entities TYPE array<string> DEFAULT [];
DEFINE FIELD jsonld_context ON knowledge_entities TYPE object;
DEFINE FIELD jsonld_type ON knowledge_entities TYPE array<string> DEFAULT ['schema:Thing', 'agx:KnowledgeEntity'];
DEFINE FIELD trust_score ON knowledge_entities TYPE option<number> ASSERT $value = NONE OR ($value >= 0 AND $value <= 1);
DEFINE FIELD created_at ON knowledge_entities TYPE datetime DEFAULT time::now();
DEFINE INDEX knowledge_entities_tenant_semantic_unique ON knowledge_entities FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE knowledge_chunks SCHEMAFULL;
DEFINE FIELD tenant_id ON knowledge_chunks TYPE record<tenants>;
DEFINE FIELD document_id ON knowledge_chunks TYPE option<record<source_documents>>;
DEFINE FIELD region_id ON knowledge_chunks TYPE option<record<document_regions>>;
DEFINE FIELD content ON knowledge_chunks TYPE string;
DEFINE FIELD chunk_kind ON knowledge_chunks TYPE string DEFAULT 'text';
DEFINE FIELD semantic_id ON knowledge_chunks TYPE string;
DEFINE FIELD jsonld_context ON knowledge_chunks TYPE object;
DEFINE FIELD jsonld_type ON knowledge_chunks TYPE array<string> DEFAULT ['schema:CreativeWork', 'agx:KnowledgeChunk'];
DEFINE FIELD embedding_ref ON knowledge_chunks TYPE option<string>;
DEFINE FIELD created_at ON knowledge_chunks TYPE datetime DEFAULT time::now();
DEFINE INDEX knowledge_chunks_tenant_semantic_unique ON knowledge_chunks FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE knowledge_modalities SCHEMAFULL;
DEFINE FIELD tenant_id ON knowledge_modalities TYPE record<tenants>;
DEFINE FIELD region_id ON knowledge_modalities TYPE option<record<document_regions>>;
DEFINE FIELD chunk_id ON knowledge_modalities TYPE option<record<knowledge_chunks>>;
DEFINE FIELD modality_kind ON knowledge_modalities TYPE string;
DEFINE FIELD payload_ref ON knowledge_modalities TYPE option<string>;
DEFINE FIELD extracted_text ON knowledge_modalities TYPE option<string>;
DEFINE FIELD semantic_id ON knowledge_modalities TYPE string;
DEFINE FIELD jsonld_context ON knowledge_modalities TYPE object;
DEFINE FIELD jsonld_type ON knowledge_modalities TYPE array<string> DEFAULT ['schema:MediaObject', 'agx:KnowledgeModality'];
DEFINE FIELD created_at ON knowledge_modalities TYPE datetime DEFAULT time::now();
DEFINE INDEX knowledge_modalities_tenant_semantic_unique ON knowledge_modalities FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE knowledge_communities SCHEMAFULL;
DEFINE FIELD tenant_id ON knowledge_communities TYPE record<tenants>;
DEFINE FIELD name ON knowledge_communities TYPE string;
DEFINE FIELD community_level ON knowledge_communities TYPE int DEFAULT 0;
DEFINE FIELD semantic_id ON knowledge_communities TYPE string;
DEFINE FIELD jsonld_context ON knowledge_communities TYPE object;
DEFINE FIELD jsonld_type ON knowledge_communities TYPE array<string> DEFAULT ['schema:Thing', 'agx:KnowledgeCommunity'];
DEFINE FIELD created_at ON knowledge_communities TYPE datetime DEFAULT time::now();
DEFINE INDEX knowledge_communities_tenant_semantic_unique ON knowledge_communities FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE knowledge_summaries SCHEMAFULL;
DEFINE FIELD tenant_id ON knowledge_summaries TYPE record<tenants>;
DEFINE FIELD summary_kind ON knowledge_summaries TYPE string;
DEFINE FIELD content ON knowledge_summaries TYPE string;
DEFINE FIELD semantic_id ON knowledge_summaries TYPE string;
DEFINE FIELD jsonld_context ON knowledge_summaries TYPE object;
DEFINE FIELD jsonld_type ON knowledge_summaries TYPE array<string> DEFAULT ['schema:CreativeWork', 'agx:KnowledgeSummary'];
DEFINE FIELD source_grounding_refs ON knowledge_summaries TYPE array<string> DEFAULT ['microsoft:graphrag'];
DEFINE FIELD created_at ON knowledge_summaries TYPE datetime DEFAULT time::now();
DEFINE INDEX knowledge_summaries_tenant_semantic_unique ON knowledge_summaries FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE retrieval_runs SCHEMAFULL;
DEFINE FIELD tenant_id ON retrieval_runs TYPE record<tenants>;
DEFINE FIELD agent_id ON retrieval_runs TYPE option<record<agents>>;
DEFINE FIELD query_text ON retrieval_runs TYPE string;
DEFINE FIELD query_context ON retrieval_runs TYPE object DEFAULT {};
DEFINE FIELD status ON retrieval_runs TYPE string DEFAULT 'running';
DEFINE FIELD strategy ON retrieval_runs TYPE string DEFAULT 'hybrid_graph_multimodal';
DEFINE FIELD semantic_id ON retrieval_runs TYPE string;
DEFINE FIELD jsonld_context ON retrieval_runs TYPE object;
DEFINE FIELD jsonld_type ON retrieval_runs TYPE array<string> DEFAULT ['schema:SearchAction', 'agx:RetrievalRun'];
DEFINE FIELD source_grounding_refs ON retrieval_runs TYPE array<string> DEFAULT ['microsoft:graphrag', 'arxiv:2510.12323'];
DEFINE FIELD started_at ON retrieval_runs TYPE datetime DEFAULT time::now();
DEFINE FIELD ended_at ON retrieval_runs TYPE option<datetime>;
DEFINE INDEX retrieval_runs_tenant_semantic_unique ON retrieval_runs FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE retrieval_steps SCHEMAFULL;
DEFINE FIELD tenant_id ON retrieval_steps TYPE record<tenants>;
DEFINE FIELD retrieval_run_id ON retrieval_steps TYPE record<retrieval_runs>;
DEFINE FIELD sequence ON retrieval_steps TYPE int;
DEFINE FIELD step_kind ON retrieval_steps TYPE string;
DEFINE FIELD input ON retrieval_steps TYPE object DEFAULT {};
DEFINE FIELD output ON retrieval_steps TYPE object DEFAULT {};
DEFINE FIELD status ON retrieval_steps TYPE string DEFAULT 'completed';
DEFINE FIELD semantic_id ON retrieval_steps TYPE string;
DEFINE FIELD jsonld_context ON retrieval_steps TYPE object;
DEFINE FIELD jsonld_type ON retrieval_steps TYPE array<string> DEFAULT ['schema:Action', 'agx:RetrievalStep'];
DEFINE FIELD observed_at ON retrieval_steps TYPE datetime DEFAULT time::now();
DEFINE INDEX retrieval_steps_run_sequence_unique ON retrieval_steps FIELDS retrieval_run_id, sequence UNIQUE;

DEFINE TABLE retrieved_evidence SCHEMAFULL;
DEFINE FIELD tenant_id ON retrieved_evidence TYPE record<tenants>;
DEFINE FIELD retrieval_run_id ON retrieved_evidence TYPE record<retrieval_runs>;
DEFINE FIELD evidence_ref ON retrieved_evidence TYPE record;
DEFINE FIELD evidence_kind ON retrieved_evidence TYPE string;
DEFINE FIELD score ON retrieved_evidence TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD graph_distance ON retrieved_evidence TYPE option<int>;
DEFINE FIELD modality_support ON retrieved_evidence TYPE array<string> DEFAULT [];
DEFINE FIELD semantic_id ON retrieved_evidence TYPE string;
DEFINE FIELD jsonld_context ON retrieved_evidence TYPE object;
DEFINE FIELD jsonld_type ON retrieved_evidence TYPE array<string> DEFAULT ['schema:CreativeWork', 'agx:RetrievedEvidence'];
DEFINE FIELD created_at ON retrieved_evidence TYPE datetime DEFAULT time::now();

DEFINE TABLE evidence_critiques SCHEMAFULL;
DEFINE FIELD tenant_id ON evidence_critiques TYPE record<tenants>;
DEFINE FIELD retrieval_run_id ON evidence_critiques TYPE record<retrieval_runs>;
DEFINE FIELD evidence_id ON evidence_critiques TYPE record<retrieved_evidence>;
DEFINE FIELD relevance_score ON evidence_critiques TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD cultural_alignment_score ON evidence_critiques TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD citation_quality_score ON evidence_critiques TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD contradiction_score ON evidence_critiques TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD explanation ON evidence_critiques TYPE object DEFAULT {};
DEFINE FIELD semantic_id ON evidence_critiques TYPE string;
DEFINE FIELD jsonld_context ON evidence_critiques TYPE object;
DEFINE FIELD jsonld_type ON evidence_critiques TYPE array<string> DEFAULT ['schema:Review', 'agx:EvidenceCritique'];
DEFINE FIELD created_at ON evidence_critiques TYPE datetime DEFAULT time::now();

DEFINE TABLE evidence_sufficiency_checks SCHEMAFULL;
DEFINE FIELD tenant_id ON evidence_sufficiency_checks TYPE record<tenants>;
DEFINE FIELD retrieval_run_id ON evidence_sufficiency_checks TYPE record<retrieval_runs>;
DEFINE FIELD sufficient ON evidence_sufficiency_checks TYPE bool;
DEFINE FIELD sufficiency_score ON evidence_sufficiency_checks TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD missing_evidence ON evidence_sufficiency_checks TYPE array<string> DEFAULT [];
DEFINE FIELD decision ON evidence_sufficiency_checks TYPE string;
DEFINE FIELD semantic_id ON evidence_sufficiency_checks TYPE string;
DEFINE FIELD jsonld_context ON evidence_sufficiency_checks TYPE object;
DEFINE FIELD jsonld_type ON evidence_sufficiency_checks TYPE array<string> DEFAULT ['schema:Action', 'agx:EvidenceSufficiencyCheck'];
DEFINE FIELD created_at ON evidence_sufficiency_checks TYPE datetime DEFAULT time::now();

DEFINE TABLE contains_document SCHEMAFULL TYPE RELATION IN retrieval_corpora OUT source_documents;
DEFINE FIELD tenant_id ON contains_document TYPE record<tenants>;
DEFINE TABLE has_region SCHEMAFULL TYPE RELATION IN source_documents OUT document_regions;
DEFINE FIELD tenant_id ON has_region TYPE record<tenants>;
DEFINE TABLE has_chunk SCHEMAFULL TYPE RELATION IN source_documents|document_regions OUT knowledge_chunks;
DEFINE FIELD tenant_id ON has_chunk TYPE record<tenants>;
DEFINE TABLE mentions_entity SCHEMAFULL TYPE RELATION IN knowledge_chunks|document_regions OUT knowledge_entities;
DEFINE FIELD tenant_id ON mentions_entity TYPE record<tenants>;
DEFINE TABLE has_modality SCHEMAFULL TYPE RELATION IN knowledge_chunks|document_regions OUT knowledge_modalities;
DEFINE FIELD tenant_id ON has_modality TYPE record<tenants>;
DEFINE TABLE cross_modal_related_to SCHEMAFULL TYPE RELATION IN knowledge_modalities|knowledge_chunks|knowledge_entities OUT knowledge_modalities|knowledge_chunks|knowledge_entities;
DEFINE FIELD tenant_id ON cross_modal_related_to TYPE record<tenants>;
DEFINE FIELD relation_score ON cross_modal_related_to TYPE number DEFAULT 1 ASSERT $value >= 0 AND $value <= 1;
DEFINE TABLE text_semantically_related_to SCHEMAFULL TYPE RELATION IN knowledge_chunks|knowledge_entities OUT knowledge_chunks|knowledge_entities;
DEFINE FIELD tenant_id ON text_semantically_related_to TYPE record<tenants>;
DEFINE FIELD relation_score ON text_semantically_related_to TYPE number DEFAULT 1 ASSERT $value >= 0 AND $value <= 1;
DEFINE TABLE entity_related_to SCHEMAFULL TYPE RELATION IN knowledge_entities OUT knowledge_entities;
DEFINE FIELD tenant_id ON entity_related_to TYPE record<tenants>;
DEFINE FIELD predicate ON entity_related_to TYPE string;
DEFINE FIELD relation_score ON entity_related_to TYPE number DEFAULT 1 ASSERT $value >= 0 AND $value <= 1;
DEFINE TABLE belongs_to_community SCHEMAFULL TYPE RELATION IN knowledge_entities OUT knowledge_communities;
DEFINE FIELD tenant_id ON belongs_to_community TYPE record<tenants>;
DEFINE TABLE summarizes SCHEMAFULL TYPE RELATION IN knowledge_summaries OUT knowledge_entities|knowledge_communities|source_documents;
DEFINE FIELD tenant_id ON summarizes TYPE record<tenants>;
DEFINE TABLE retrieval_returned_evidence SCHEMAFULL TYPE RELATION IN retrieval_runs OUT retrieved_evidence;
DEFINE FIELD tenant_id ON retrieval_returned_evidence TYPE record<tenants>;
DEFINE TABLE evidence_supported_by SCHEMAFULL TYPE RELATION IN retrieved_evidence OUT knowledge_chunks|knowledge_entities|knowledge_modalities|knowledge_summaries;
DEFINE FIELD tenant_id ON evidence_supported_by TYPE record<tenants>;
