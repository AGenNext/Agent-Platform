-- AGenNext SurrealDB-first agent module substrate
-- Default modules are loaded for every agent created from the platform.

DEFINE TABLE tenants SCHEMAFULL;
DEFINE FIELD name ON tenants TYPE string;
DEFINE FIELD semantic_id ON tenants TYPE string;
DEFINE FIELD jsonld_context ON tenants TYPE object;
DEFINE FIELD jsonld_type ON tenants TYPE array<string>;
DEFINE FIELD created_at ON tenants TYPE datetime DEFAULT time::now();
DEFINE INDEX tenants_semantic_id_unique ON tenants FIELDS semantic_id UNIQUE;

DEFINE TABLE agents SCHEMAFULL;
DEFINE FIELD tenant_id ON agents TYPE record<tenants>;
DEFINE FIELD name ON agents TYPE string;
DEFINE FIELD semantic_id ON agents TYPE string;
DEFINE FIELD jsonld_context ON agents TYPE object;
DEFINE FIELD jsonld_type ON agents TYPE array<string>;
DEFINE FIELD source_grounding_refs ON agents TYPE array<string> DEFAULT [];
DEFINE FIELD default_modules_loaded ON agents TYPE bool DEFAULT false;
DEFINE FIELD trust_policy_id ON agents TYPE option<record<trust_policies>>;
DEFINE FIELD created_at ON agents TYPE datetime DEFAULT time::now();
DEFINE FIELD updated_at ON agents TYPE datetime DEFAULT time::now();
DEFINE INDEX agents_tenant_semantic_unique ON agents FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE agent_modules SCHEMAFULL;
DEFINE FIELD key ON agent_modules TYPE string;
DEFINE FIELD name ON agent_modules TYPE string;
DEFINE FIELD description ON agent_modules TYPE string;
DEFINE FIELD enabled_by_default ON agent_modules TYPE bool DEFAULT false;
DEFINE FIELD load_order ON agent_modules TYPE int;
DEFINE FIELD jsonld_context ON agent_modules TYPE object;
DEFINE FIELD jsonld_type ON agent_modules TYPE array<string>;
DEFINE FIELD source_grounding_refs ON agent_modules TYPE array<string> DEFAULT [];
DEFINE FIELD config_schema ON agent_modules TYPE object DEFAULT {};
DEFINE FIELD created_at ON agent_modules TYPE datetime DEFAULT time::now();
DEFINE INDEX agent_modules_key_unique ON agent_modules FIELDS key UNIQUE;

DEFINE TABLE agent_module_instances SCHEMAFULL;
DEFINE FIELD tenant_id ON agent_module_instances TYPE record<tenants>;
DEFINE FIELD agent_id ON agent_module_instances TYPE record<agents>;
DEFINE FIELD module_id ON agent_module_instances TYPE record<agent_modules>;
DEFINE FIELD key ON agent_module_instances TYPE string;
DEFINE FIELD enabled ON agent_module_instances TYPE bool DEFAULT true;
DEFINE FIELD config ON agent_module_instances TYPE object DEFAULT {};
DEFINE FIELD status ON agent_module_instances TYPE string DEFAULT 'active';
DEFINE FIELD loaded_at ON agent_module_instances TYPE datetime DEFAULT time::now();
DEFINE INDEX agent_module_instance_unique ON agent_module_instances FIELDS tenant_id, agent_id, key UNIQUE;

DEFINE TABLE observation_runs SCHEMAFULL;
DEFINE FIELD tenant_id ON observation_runs TYPE record<tenants>;
DEFINE FIELD agent_id ON observation_runs TYPE option<record<agents>>;
DEFINE FIELD run_kind ON observation_runs TYPE string;
DEFINE FIELD semantic_id ON observation_runs TYPE string;
DEFINE FIELD jsonld_context ON observation_runs TYPE object;
DEFINE FIELD jsonld_type ON observation_runs TYPE array<string>;
DEFINE FIELD status ON observation_runs TYPE string DEFAULT 'running';
DEFINE FIELD started_at ON observation_runs TYPE datetime DEFAULT time::now();
DEFINE FIELD ended_at ON observation_runs TYPE option<datetime>;
DEFINE FIELD method_version ON observation_runs TYPE string;
DEFINE FIELD source_grounding_refs ON observation_runs TYPE array<string> DEFAULT [];
DEFINE INDEX observation_runs_tenant_semantic_unique ON observation_runs FIELDS tenant_id, semantic_id UNIQUE;

DEFINE TABLE observation_steps SCHEMAFULL;
DEFINE FIELD tenant_id ON observation_steps TYPE record<tenants>;
DEFINE FIELD run_id ON observation_steps TYPE record<observation_runs>;
DEFINE FIELD agent_id ON observation_steps TYPE option<record<agents>>;
DEFINE FIELD parent_step_id ON observation_steps TYPE option<record<observation_steps>>;
DEFINE FIELD previous_step_id ON observation_steps TYPE option<record<observation_steps>>;
DEFINE FIELD sequence ON observation_steps TYPE int;
DEFINE FIELD step_kind ON observation_steps TYPE string;
DEFINE FIELD semantic_id ON observation_steps TYPE string;
DEFINE FIELD jsonld_context ON observation_steps TYPE object;
DEFINE FIELD jsonld_type ON observation_steps TYPE array<string>;
DEFINE FIELD actor_id ON observation_steps TYPE option<record>;
DEFINE FIELD input ON observation_steps TYPE object DEFAULT {};
DEFINE FIELD output ON observation_steps TYPE object DEFAULT {};
DEFINE FIELD status ON observation_steps TYPE string DEFAULT 'completed';
DEFINE FIELD started_at ON observation_steps TYPE datetime DEFAULT time::now();
DEFINE FIELD ended_at ON observation_steps TYPE option<datetime>;
DEFINE FIELD observed_at ON observation_steps TYPE datetime DEFAULT time::now();
DEFINE FIELD method_version ON observation_steps TYPE string;
DEFINE FIELD evidence_ids ON observation_steps TYPE array<record> DEFAULT [];
DEFINE FIELD graph_path ON observation_steps TYPE object DEFAULT {};
DEFINE FIELD explanation ON observation_steps TYPE object DEFAULT {};
DEFINE FIELD error ON observation_steps TYPE option<object>;
DEFINE INDEX observation_steps_run_sequence_unique ON observation_steps FIELDS run_id, sequence UNIQUE;

DEFINE TABLE trust_policies SCHEMAFULL;
DEFINE FIELD tenant_id ON trust_policies TYPE option<record<tenants>>;
DEFINE FIELD key ON trust_policies TYPE string;
DEFINE FIELD name ON trust_policies TYPE string;
DEFINE FIELD scope ON trust_policies TYPE string;
DEFINE FIELD thresholds ON trust_policies TYPE object;
DEFINE FIELD caps ON trust_policies TYPE object;
DEFINE FIELD method_version ON trust_policies TYPE string;
DEFINE FIELD source_grounding_refs ON trust_policies TYPE array<string> DEFAULT [];
DEFINE FIELD created_at ON trust_policies TYPE datetime DEFAULT time::now();
DEFINE INDEX trust_policies_key_unique ON trust_policies FIELDS key UNIQUE;

DEFINE TABLE trust_assertions SCHEMAFULL;
DEFINE FIELD tenant_id ON trust_assertions TYPE option<record<tenants>>;
DEFINE FIELD subject_id ON trust_assertions TYPE string;
DEFINE FIELD issuer_id ON trust_assertions TYPE string;
DEFINE FIELD evaluator_id ON trust_assertions TYPE option<string>;
DEFINE FIELD scope ON trust_assertions TYPE object;
DEFINE FIELD score ON trust_assertions TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD confidence ON trust_assertions TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD method_version ON trust_assertions TYPE string;
DEFINE FIELD evidence_ids ON trust_assertions TYPE array<record<trust_evidence>> DEFAULT [];
DEFINE FIELD valid_from ON trust_assertions TYPE datetime DEFAULT time::now();
DEFINE FIELD valid_until ON trust_assertions TYPE option<datetime>;
DEFINE FIELD revoked ON trust_assertions TYPE bool DEFAULT false;
DEFINE FIELD jsonld_context ON trust_assertions TYPE object;
DEFINE FIELD jsonld_type ON trust_assertions TYPE array<string>;
DEFINE FIELD created_at ON trust_assertions TYPE datetime DEFAULT time::now();

DEFINE TABLE trust_evidence SCHEMAFULL;
DEFINE FIELD tenant_id ON trust_evidence TYPE option<record<tenants>>;
DEFINE FIELD subject_id ON trust_evidence TYPE string;
DEFINE FIELD evidence_kind ON trust_evidence TYPE string;
DEFINE FIELD source_id ON trust_evidence TYPE string;
DEFINE FIELD weight ON trust_evidence TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD confidence ON trust_evidence TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD payload ON trust_evidence TYPE object DEFAULT {};
DEFINE FIELD observed_at ON trust_evidence TYPE datetime DEFAULT time::now();
DEFINE FIELD source_grounding_refs ON trust_evidence TYPE array<string> DEFAULT [];
DEFINE FIELD jsonld_context ON trust_evidence TYPE object;
DEFINE FIELD jsonld_type ON trust_evidence TYPE array<string>;

DEFINE TABLE trust_scores SCHEMAFULL;
DEFINE FIELD tenant_id ON trust_scores TYPE option<record<tenants>>;
DEFINE FIELD subject_id ON trust_scores TYPE string;
DEFINE FIELD evaluator_id ON trust_scores TYPE string;
DEFINE FIELD scope ON trust_scores TYPE object;
DEFINE FIELD score ON trust_scores TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD confidence ON trust_scores TYPE number ASSERT $value >= 0 AND $value <= 1;
DEFINE FIELD method_version ON trust_scores TYPE string;
DEFINE FIELD component_scores ON trust_scores TYPE object;
DEFINE FIELD caps_applied ON trust_scores TYPE array<string> DEFAULT [];
DEFINE FIELD penalties_applied ON trust_scores TYPE object DEFAULT {};
DEFINE FIELD explanation ON trust_scores TYPE object;
DEFINE FIELD evidence_ids ON trust_scores TYPE array<record<trust_evidence>> DEFAULT [];
DEFINE FIELD observation_run_id ON trust_scores TYPE record<observation_runs>;
DEFINE FIELD observation_step_ids ON trust_scores TYPE array<record<observation_steps>> DEFAULT [];
DEFINE FIELD computed_at ON trust_scores TYPE datetime DEFAULT time::now();
DEFINE FIELD jsonld_context ON trust_scores TYPE object;
DEFINE FIELD jsonld_type ON trust_scores TYPE array<string>;

DEFINE TABLE audit_logs SCHEMAFULL;
DEFINE FIELD tenant_id ON audit_logs TYPE option<record<tenants>>;
DEFINE FIELD actor_id ON audit_logs TYPE option<string>;
DEFINE FIELD action ON audit_logs TYPE string;
DEFINE FIELD resource_type ON audit_logs TYPE string;
DEFINE FIELD resource_id ON audit_logs TYPE option<string>;
DEFINE FIELD request_id ON audit_logs TYPE option<string>;
DEFINE FIELD ip_address ON audit_logs TYPE option<string>;
DEFINE FIELD user_agent ON audit_logs TYPE option<string>;
DEFINE FIELD metadata ON audit_logs TYPE object DEFAULT {};
DEFINE FIELD semantic_id ON audit_logs TYPE string;
DEFINE FIELD jsonld_context ON audit_logs TYPE object;
DEFINE FIELD jsonld_type ON audit_logs TYPE array<string>;
DEFINE FIELD time ON audit_logs TYPE object;
DEFINE FIELD created_at ON audit_logs TYPE datetime DEFAULT time::now();

DEFINE TABLE agent_registries SCHEMAFULL;
DEFINE FIELD name ON agent_registries TYPE string;
DEFINE FIELD registry_url ON agent_registries TYPE string;
DEFINE FIELD trust_score ON agent_registries TYPE option<number> ASSERT $value = NONE OR ($value >= 0 AND $value <= 1);
DEFINE FIELD jsonld_context ON agent_registries TYPE object;
DEFINE FIELD jsonld_type ON agent_registries TYPE array<string>;
DEFINE FIELD source_grounding_refs ON agent_registries TYPE array<string> DEFAULT [];
DEFINE INDEX agent_registries_url_unique ON agent_registries FIELDS registry_url UNIQUE;

DEFINE TABLE external_agent_profiles SCHEMAFULL;
DEFINE FIELD registry_id ON external_agent_profiles TYPE record<agent_registries>;
DEFINE FIELD external_id ON external_agent_profiles TYPE string;
DEFINE FIELD semantic_id ON external_agent_profiles TYPE string;
DEFINE FIELD did ON external_agent_profiles TYPE option<string>;
DEFINE FIELD same_as ON external_agent_profiles TYPE array<string> DEFAULT [];
DEFINE FIELD profile_jsonld ON external_agent_profiles TYPE object;
DEFINE FIELD imported_as_claim ON external_agent_profiles TYPE bool DEFAULT true;
DEFINE FIELD verified ON external_agent_profiles TYPE bool DEFAULT false;
DEFINE FIELD revoked ON external_agent_profiles TYPE bool DEFAULT false;
DEFINE FIELD observed_at ON external_agent_profiles TYPE datetime DEFAULT time::now();
DEFINE INDEX external_agent_profile_unique ON external_agent_profiles FIELDS registry_id, external_id UNIQUE;
