# ─────────────────────────────────────────────────────────────────────────────
# agent-knowledge-api environment
# Copy to .env — never commit .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SurrealDB connection ───────────────────────────────────────────────────────
# local:      ws://localhost:8000/rpc
# production: wss://agent-surrealdb.fly.dev/rpc  (set via fly secrets)
SURREALDB_URL=ws://localhost:8000/rpc
SURREALDB_NAMESPACE=agent_platform
SURREALDB_DATABASE=agent_platform
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8001
LOG_LEVEL=info

# ── CORS (comma-separated origins, * for local dev) ──────────────────────────
ALLOWED_ORIGINS=*
# production example:
# ALLOWED_ORIGINS=https://your-dashboard.netlify.app

# ── Auth (leave blank to disable JWT enforcement locally) ────────────────────
# JWT_SECRET=
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440
